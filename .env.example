# ============================================================
# Very AI Configuration
# Copy this file to .env.local and fill in your values.
# ============================================================
#
# Two ways to run locally:
#
#   A) Docker Compose (quick start / demo):
#      cp .env.example .env.local && docker compose up
#      → Uses defaults below as-is. No changes needed.
#      → Uncomment SUPABASE_URL=http://kong:8000 if server-side calls fail.
#      → Note: No access to Supabase Studio (DB management UI).
#
#   B) Supabase CLI + npm run dev (recommended for production / development):
#      supabase start && npm run dev
#      → Replace Supabase keys below with output from `supabase status`.
#      → Do NOT set SUPABASE_URL (leave it commented out).
#      → Gives access to Supabase Studio at http://localhost:54323
#        for managing azure_groups, users, migrations, and data.
#
# ============================================================


# ============================================================
# REQUIRED — Core (both Docker Compose and Supabase CLI)
# ============================================================

# ---- Supabase (Database & Auth) ----
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ---- Application ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=dev-secret-change-in-production

# ---- Docker Compose only ----
# Server-side Supabase URL. Inside Docker the app cannot reach "localhost",
# it must use the Kong service name. docker-compose.yml sets this automatically,
# but uncomment here if server-side calls fail.
# Do NOT set this when using supabase start + npm run dev.
# SUPABASE_URL=http://kong:8000


# ============================================================
# OPTIONAL — LLM Providers (leave empty for mock/demo mode)
# ============================================================
# Without any API keys, chat returns pre-built demo responses.
# Add one or more keys below to enable real AI responses.

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_GPT_4O_DEPLOYMENT_ID=
# AZURE_IMAGINE_DEPLOYMENT=                 # e.g. dall-e-3
# AZURE_IMAGINE_API_VERSION=2024-02-01

# Anthropic / Claude
# ANTHROPIC_API_KEY=

# Google Gemini (API key)
# GOOGLE_GEMINI_API_KEY=

# Google Gemini (Vertex AI — service account for enterprise)
# VERTEX_AI_GEMINI_PROJECT_ID=
# VERTEX_AI_GEMINI_LOCATION=europe-west1
# GOOGLE_SERVICE_ACCOUNT_CREDENTIALS=       # JSON string or path to service account file

# DeepSeek
# DEEPSEEK_API_ENDPOINT=
# DEEPSEEK_API_SERVICE_ACCOUNT=

# Mistral
# MISTRAL_API_ENDPOINT=

# Ollama (local models)
# NEXT_PUBLIC_OLLAMA_URL=http://localhost:11434

# OpenAI Organization
# NEXT_PUBLIC_OPENAI_ORGANIZATION_ID=


# ============================================================
# OPTIONAL — Azure Entra ID SSO (replaces email/password login)
# ============================================================
# When all three AUTH_AZURE_AD_* vars are set, the login page
# switches to "Login with Microsoft" automatically.
# NEXT_LOGIN_PASSWORD bridges the Entra session into GoTrue —
# generate a strong random string (REQUIRED when using Entra).

# AUTH_AZURE_AD_TENANT_ID=
# AUTH_AZURE_AD_ID=
# AUTH_AZURE_AD_SECRET=
# NEXT_LOGIN_PASSWORD=


# ============================================================
# OPTIONAL — PII Detection & Re-Anonymization
# ============================================================

# Azure Text Analytics
# AZURE_PII_ENDPOINT=
# AZURE_PII_API_KEY=

# Presidio (self-hosted)
# PRESIDIO_ANALYZER_ENDPOINT=
# PRESIDIO_ANONYMIZER_ENDPOINT=


# ============================================================
# OPTIONAL — Integrations
# ============================================================

# n8n Workflow Integration
# N8N_CALLBACK_URL=
# N8N_CALLBACK_SECRET=
# N8N_GOOGLE_WEBSEARCH_ENDPOINT=
# N8N_WEBSEARCH_API_KEY=

# Search
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_CX=
# MAPS_API_KEY=

# Crawler
# CRAWLER_MAX_PAGES=10
# CRAWLER_MAX_DEPTH=3

# File Processing
# PDF_ENDPOINT=
# PDF_API_KEY=
# NEXT_PUBLIC_USER_FILE_SIZE_LIMIT=          # Max file size in bytes
# NEXT_PUBLIC_CHUNK_UPLOAD_SIZE=             # Chunk size for large uploads

# Azure Integrations
# AZURE_PF_ENDPOINT=                        # PromptFlow endpoint
# AZURE_PF_BEARER_TOKEN=
# AZURE_SHAREPOINT_DEPLOYMENT=
# AZURE_TEAMS_DEPLOYMENT=
# AZURE_WEB_DEPLOYMENT=

# OneDrive
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_TENANT_ID=
# ONEDRIVE_CLIENT_ID_PERSONAL=(if not using Azure AD)


# ============================================================
# OPTIONAL — Operations
# ============================================================

# Logging & Monitoring
# LOG_ACCESS_TOKEN=                          # Token to access /api/logs
# LOG_CLEANUP_HOURS=168                      # Auto-delete logs older than N hours

# Security
# TRUSTED_HOSTS=localhost,very-ai.eu         # Comma-separated trusted hostnames

# Support
# NEXT_PUBLIC_SUPPORT_URL=                   # Support page URL shown in UI
