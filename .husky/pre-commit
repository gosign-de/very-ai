#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Get list of staged TypeScript/TSX files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)

if [ -n "$STAGED_FILES" ]; then
  # Run lint and format only on staged files
  echo "$STAGED_FILES" | xargs npx eslint --fix || exit 1
  echo "$STAGED_FILES" | xargs npx prettier --write || exit 1

  # Re-add the formatted files to staging (handles filenames with spaces)
  echo "$STAGED_FILES" | tr '\n' '\0' | xargs -0 git add
fi